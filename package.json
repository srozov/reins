{
  "name": "@agi01/reins",
  "version": "0.2.0",
  "description": "Universal MCP adapter for CLI-based coding agents (Claude Code, Codex, OpenCode). Control and orchestrate AI coding harnesses via MCP.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "reins": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "node --loader ts-node/esm src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "reins",
    "harness",
    "agent-framework"
  ],
  "author": "AGI01",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "optionalDependencies": {
    "ws": "^8.19.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
